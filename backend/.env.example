# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/producao_na_mao

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-min-64-chars-hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# Chave para criptografar dados sensíveis no banco (API keys de ERP/WhatsApp)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-fernet-key=

# ── Anthropic Claude (consultor IA) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000

# ── Armazenamento de arquivos ──────────────────────────────────────────────────
STORAGE_TYPE=local
LOCAL_UPLOAD_DIR=uploads/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=producao-na-mao
# AWS_S3_REGION=sa-east-1
